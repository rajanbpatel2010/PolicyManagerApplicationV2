<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=ATPL-LAP-484\MSSQLSERVER2022;Initial Catalog=PolicyManagerDB</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="PolicyRegister">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>usp_Report_PolicyRegister</CommandText>
      </Query>
      <Fields>
        <Field Name="PolicyNumber"><DataField>PolicyNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PolicyHolderName"><DataField>PolicyHolderName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Email"><DataField>Email</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PolicyTypeName"><DataField>PolicyTypeName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PremiumAmount"><DataField>PremiumAmount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="CoverageAmount"><DataField>CoverageAmount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="StartDate"><DataField>StartDate</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="EndDate"><DataField>EndDate</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="Status"><DataField>Status</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="Title">
            <CanGrow>true</CanGrow>
            <Paragraphs><Paragraph><TextRuns><TextRun><Value>Detailed Policy Register Report</Value><Style><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
            <Height>0.4in</Height>
            <Width>6.5in</Width>
          </Textbox>
          <Tablix Name="Tablix1">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>1in</Width></TablixColumn>
                <TablixColumn><Width>1.25in</Width></TablixColumn>
                <TablixColumn><Width>0.75in</Width></TablixColumn>
                <TablixColumn><Width>0.75in</Width></TablixColumn>
                <TablixColumn><Width>0.75in</Width></TablixColumn>
                <TablixColumn><Width>0.75in</Width></TablixColumn>
                <TablixColumn><Width>0.75in</Width></TablixColumn>
                <TablixColumn><Width>0.5in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="h1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Policy #</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Holder</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Type</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Premium</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Coverage</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Start</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>End</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Stat</Value><Style><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.2in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="PolicyNumber"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PolicyNumber.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="PolicyHolderName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PolicyHolderName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="PolicyTypeName"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PolicyTypeName.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="PremiumAmount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!PremiumAmount.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="CoverageAmount"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!CoverageAmount.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="StartDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!StartDate.Value, "dd-MM-yyyy")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="EndDate"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!EndDate.Value, "dd-MM-yyyy")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="Status"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Status.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember><TablixMember><Group Name="Details" /></TablixMember></TablixMembers></TablixRowHierarchy>
            <DataSetName>PolicyRegister</DataSetName>
            <Top>0.5in</Top>
            <Height>0.45in</Height>
          </Tablix>
        </ReportItems>
        <Height>1.5in</Height>
      </Body>
      <Width>7in</Width>
      <Page><LeftMargin>0.5in</LeftMargin><RightMargin>0.5in</RightMargin></Page>
    </ReportSection>
  </ReportSections>
</Report>
